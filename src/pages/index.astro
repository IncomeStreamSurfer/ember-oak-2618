---
import Base from '../layouts/Base.astro';
---
<Base title="Ember & Oak — building...">
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-xl">
      <div class="text-6xl mb-6 flame">🕯️</div>
      <h1 class="text-4xl md:text-5xl font-semibold mb-4">Ember &amp; Oak</h1>
      <p class="text-lg text-neutral-600 mb-8 font-sans">Hand-pouring your shop now. The candles are cooling.</p>
      <div class="inline-block px-4 py-2 rounded-full bg-[var(--cream)] text-sm font-sans text-[var(--oak)]">
        Building your store · please wait
      </div>
    </div>
  </main>
</Base>
