---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { stripe } from '../lib/stripe';
import { formatPrice } from '../lib/stripe';

const sessionId = Astro.url.searchParams.get('session_id');
let email: string | null = null;
let total = 0;
let currency = 'gbp';

if (sessionId) {
  try {
    const s = await stripe.checkout.sessions.retrieve(sessionId);
    email = s.customer_details?.email || null;
    total = s.amount_total || 0;
    currency = s.currency || 'gbp';
  } catch (e) {
    console.error('[success] retrieve failed:', e);
  }
}
---
<Base title="Thank you — Ember & Oak">
  <Nav />

  <main class="max-w-2xl mx-auto px-6 py-20 text-center">
    <div class="text-6xl mb-6 flame">🕯️</div>
    <h1 class="text-4xl md:text-5xl font-semibold mb-4">Thank you.</h1>
    <p class="text-lg text-neutral-600 font-sans mb-2">Your order is in. We'll hand-pour, pack, and ship within 3 working days.</p>
    {email && <p class="font-sans text-sm text-neutral-500 mb-8">Confirmation sent to <strong>{email}</strong></p>}
    {total > 0 && <p class="font-sans mb-8">Total paid: <strong>{formatPrice(total, currency)}</strong></p>}
    <a href="/" class="ember-button">Back to the shop</a>
  </main>

  <Footer />

  <script>
    // Clear cart now that payment is complete
    try { localStorage.removeItem('emberoak_cart'); window.dispatchEvent(new CustomEvent('emberoak:cart-changed')); } catch {}
  </script>
</Base>
