---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { supabase } from '../../lib/supabase';

const { slug } = Astro.params;
const { data } = await supabase
  .from('candle_content')
  .select('*')
  .eq('slug', slug)
  .maybeSingle();

if (!data || !(data as any).published_at) {
  return Astro.redirect('/journal');
}
const post = data as { title: string; body: string | null; published_at: string | null; seo_description: string | null };
---
<Base title={`${post.title} — Ember & Oak Journal`} description={post.seo_description || ''}>
  <Nav />
  <main class="max-w-2xl mx-auto px-6 py-16">
    <a href="/journal" class="font-sans text-sm text-neutral-500 ember-link">← Back to the journal</a>
    <h1 class="text-4xl md:text-5xl font-semibold mt-4 mb-4">{post.title}</h1>
    {post.published_at && <p class="font-sans text-sm text-neutral-500 mb-8">{new Date(post.published_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>}
    <div class="prose prose-lg max-w-none leading-relaxed text-neutral-700 whitespace-pre-line">{post.body}</div>
  </main>
  <Footer />
</Base>
